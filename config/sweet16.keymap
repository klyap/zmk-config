#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &studio_unlock  &kp N2  &kp N3     &kp N4
                &kp N5  &kp N6  &kp N7     &kp N8
                &kp N9  &kp N0  &kp MINUS  &kp EQUAL
                &kp Q   &kp W   &kp E      &kp R
            >;
        };
    };
};
